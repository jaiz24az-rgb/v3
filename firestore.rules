rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all at first level
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Helper function to guard against long or poisoned document IDs
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // 1. Settings Collection Validator
    function isValidSettings(data) {
      return (!('kas' in data) || data.kas is map)
        && (!('blocksList' in data) || data.blocksList is list)
        && (!('yearsList' in data) || data.yearsList is list)
        && (!('rateRT' in data) || data.rateRT is int || data.rateRT is float)
        && (!('rateRombong' in data) || data.rateRombong is int || data.rateRombong is float)
        && (!('rtTitle' in data) || (data.rtTitle is string && data.rtTitle.size() <= 1000))
        && (!('rtAddress' in data) || (data.rtAddress is string && data.rtAddress.size() <= 2000))
        && (!('rtEmail' in data) || (data.rtEmail is string && data.rtEmail.size() <= 500))
        && (!('appName' in data) || (data.appName is string && data.appName.size() <= 500))
        && (!('appLogo' in data) || (data.appLogo is string && data.appLogo.size() <= 500000))
        && (!('labelWargaSingular' in data) || (data.labelWargaSingular is string && data.labelWargaSingular.size() <= 100))
        && (!('labelWargaPlural' in data) || (data.labelWargaPlural is string && data.labelWargaPlural.size() <= 100))
        && (!('labelRombongSingular' in data) || (data.labelRombongSingular is string && data.labelRombongSingular.size() <= 100))
        && (!('labelRombongPlural' in data) || (data.labelRombongPlural is string && data.labelRombongPlural.size() <= 100))
        && (!('bankNama' in data) || (data.bankNama is string && data.bankNama.size() <= 200))
        && (!('bankNoRek' in data) || (data.bankNoRek is string && data.bankNoRek.size() <= 100))
        && (!('bankPenerima' in data) || (data.bankPenerima is string && data.bankPenerima.size() <= 200))
        && (!('bankCatatanVendor' in data) || (data.bankCatatanVendor is string && data.bankCatatanVendor.size() <= 2000))
        && (!('meetingNotulen' in data) || (data.meetingNotulen is string && data.meetingNotulen.size() <= 20000));
    }

    // Settings collection rules
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isValidId(settingId) && (request.resource == null || isValidSettings(incoming()));
    }

    // 2. Ledger entries Validator
    function isValidLedger(data) {
      return (!('id' in data) || data.id is string)
        && (!('tanggal' in data) || data.tanggal is string)
        && (!('deskripsi' in data) || (data.deskripsi is string && data.deskripsi.size() <= 2000))
        && (!('jumlah' in data) || data.jumlah is int || data.jumlah is float)
        && (!('tipe' in data) || (data.tipe is string && (data.tipe == 'pemasukan' || data.tipe == 'pengeluaran')))
        && (!('sumberKas' in data) || data.sumberKas is string)
        && (!('kategori' in data) || data.kategori is string)
        && (!('petugas' in data) || data.petugas is string)
        && (!('fotoBase64' in data) || data.fotoBase64 is string)
        && (!('fotoNamaFile' in data) || data.fotoNamaFile is string)
        && (!('isCustomRombong' in data) || data.isCustomRombong is bool)
        && (!('approvedByAdmin' in data) || data.approvedByAdmin is bool)
        && (!('needApproval' in data) || data.needApproval is bool)
        && (!('rombongId' in data) || data.rombongId is string)
        && (!('bulan' in data) || data.bulan is string)
        && (!('tahun' in data) || data.tahun is int);
    }

    // Ledger entries collection rules
    match /ledger_entries/{ledgerId} {
      allow read: if true;
      allow write: if isValidId(ledgerId) && (request.resource == null || isValidLedger(incoming()));
    }

    // 3. Warga bills Validator
    function isValidWarga(data) {
      return (!('id' in data) || data.id is string)
        && (!('nama' in data) || (data.nama is string && data.nama.size() <= 500))
        && (!('blok' in data) || data.blok is string)
        && (!('noRumah' in data) || data.noRumah is string)
        && (!('noWa' in data) || data.noWa is string)
        && (!('isDeleted' in data) || data.isDeleted is bool)
        && (!('noKtp' in data) || data.noKtp is string)
        && (!('noKk' in data) || data.noKk is string)
        && (!('alamatKtpAsal' in data) || data.alamatKtpAsal is string)
        && (!('ktpBase64' in data) || data.ktpBase64 is string)
        && (!('kkBase64' in data) || data.kkBase64 is string)
        && (!('ktpNamaFile' in data) || data.ktpNamaFile is string)
        && (!('kkNamaFile' in data) || data.kkNamaFile is string)
        && (!('fotoBase64' in data) || data.fotoBase64 is string)
        && (!('fotoNamaFile' in data) || data.fotoNamaFile is string)
        && (!('statusRumah' in data) || (data.statusRumah is string && (data.statusRumah == 'milik_sendiri' || data.statusRumah == 'sewa_kontrak' || data.statusRumah == 'lainnya')))
        && (!('tglAwalSewa' in data) || data.tglAwalSewa is string)
        && (!('tglAkhirSewa' in data) || data.tglAkhirSewa is string)
        && (!('iuranRT' in data) || data.iuranRT is list);
    }

    // Warga bills collection rules
    match /warga_bills/{wargaId} {
      allow read: if true;
      allow write: if isValidId(wargaId) && (request.resource == null || isValidWarga(incoming()));
    }

    // 4. Rombong bills Validator
    function isValidRombong(data) {
      return (!('id' in data) || data.id is string)
        && (!('namaPemilik' in data) || (data.namaPemilik is string && data.namaPemilik.size() <= 500))
        && (!('lokasi' in data) || data.lokasi is string)
        && (!('noLapak' in data) || data.noLapak is string)
        && (!('noWa' in data) || data.noWa is string)
        && (!('isDeleted' in data) || data.isDeleted is bool)
        && (!('fotoBase64' in data) || data.fotoBase64 is string)
        && (!('fotoNamaFile' in data) || data.fotoNamaFile is string)
        && (!('iuranRombong' in data) || data.iuranRombong is list);
    }

    // Rombong bills collection rules
    match /rombong_bills/{rombongId} {
      allow read: if true;
      allow write: if isValidId(rombongId) && (request.resource == null || isValidRombong(incoming()));
    }

    // 5. App User Validator
    function isValidAppUser(data) {
      return (!('id' in data) || data.id is string)
        && (!('username' in data) || data.username is string)
        && (!('pin' in data) || (data.pin is string && data.pin.size() <= 100))
        && (!('role' in data) || (data.role is string && (data.role == 'admin' || data.role == 'bendahara' || data.role == 'kolektor' || data.role == 'warga' || data.role == 'rombong' || data.role == 'sekretaris' || data.role == 'audit')))
        && (!('nama' in data) || (data.nama is string && data.nama.size() <= 200))
        && (!('wargaId' in data) || data.wargaId is string)
        && (!('rombongId' in data) || data.rombongId is string);
    }

    // App users collection
    match /app_users/{userId} {
      allow read: if true;
      allow write: if isValidId(userId) && (request.resource == null || isValidAppUser(incoming()));
    }

    // 6. Official Letter Validator
    function isValidOfficialLetter(data) {
      return (!('id' in data) || data.id is string)
        && (!('nomorSurat' in data) || (data.nomorSurat is string && data.nomorSurat.size() <= 200))
        && (!('tanggalSurat' in data) || data.tanggalSurat is string)
        && (!('jenisSurat' in data) || (data.jenisSurat is string && (data.jenisSurat == 'undangan_rapat' || data.jenisSurat == 'undangan_kerja_bakti' || data.jenisSurat == 'undangan_khusus' || data.jenisSurat == 'custom')))
        && (!('perihal' in data) || (data.perihal is string && data.perihal.size() <= 1000))
        && (!('penerima' in data) || (data.penerima is string && data.penerima.size() <= 500))
        && (!('keperluan' in data) || (data.keperluan is string && data.keperluan.size() <= 2000))
        && (!('wargaId' in data) || data.wargaId is string)
        && (!('createdAt' in data) || data.createdAt is string)
        && (!('createdBy' in data) || data.createdBy is string);
    }

    // Official letters collection rules
    match /official_letters/{letterId} {
      allow read: if true;
      allow write: if isValidId(letterId) && (request.resource == null || isValidOfficialLetter(incoming()));
    }
  }
}
